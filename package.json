{
  "name": "allka-2026-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/frontend",
    "apps/backend"
  ],
  "scripts": {
    "prisma:generate": "prisma generate --schema=apps/backend/prisma/schema.prisma",
    "dev": "concurrently -n \"backend,frontend\" -c \"blue,green\" \"npm run dev -w apps/backend\" \"npm run dev -w apps/frontend\"",
    "dev:mock": "npm run dev:mock -w apps/frontend",
    "dev:front": "npm run dev -w apps/frontend",
    "dev:backend": "npm run dev -w apps/backend",
    "build": "npm run build -w apps/frontend && npm run build -w apps/backend",
    "build:frontend": "npm run build -w apps/frontend",
    "build:backend": "npm run build -w apps/backend",
    "build:dev": "npm run build:dev -w apps/frontend",
    "preview": "npm run preview -w apps/frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}