generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Auth & Users ────────────────────────────────────────────────────────────

model User {
  id                             String    @id @default(cuid())
  // Código público/exibido (ex.: "00001") — só pra UI (tela Admin > Usuários).
  // Nunca usar no lugar de `id` em FK ou lookup técnico.
  user_code                      String?   @unique
  email                          String    @unique
  username                       String?   @unique
  password_hash                  String
  name                           String
  role                           String    @default("company_user")
  // company_user | company_admin | company_financial | agency_user | agency_admin | nomad | admin
  // ("partner"/"partner_admin" não existem mais como role própria — Partner
  // é um upgrade da própria Agency, ver PartnerProfile.)
  account_type                   String    @default("empresas")
  // empresas | agencias | nomades | admin
  // ("parceiro" não existe mais — Partner não é um account_type próprio,
  // é um status na Agency do usuário; ver PartnerProfile.agency_id.)
  is_active                      Boolean   @default(true)
  avatar                         String?   @db.LongText
  phone                          String?
  position                       String?
  admin_profile_id               String?
  company_id                     String?
  company                        Company?  @relation("CompanyMembers", fields: [company_id], references: [id])
  // ── Vínculo de subusuário (membro) com Agency — nullable: Admin, Nomad,
  // Leader e usuários órfãos legados não têm isso preenchido. Espelha o
  // padrão já usado por company_id acima.
  agency_id                      String?
  agency_link                    Agency?   @relation("AgencyMembers", fields: [agency_id], references: [id])
  last_login                     DateTime?
  // Pausa por inatividade (>=90 dias sem login) é um status derivado do
  // last_login, calculado no momento do login seguinte (ver POST
  // /api/auth/login) — não existe cron. Estes 3 campos tornam esse estado
  // "grudento": uma vez marcado, só um Admin limpa manualmente; o próprio
  // login do usuário pausado NUNCA reativa a conta sozinho.
  inactivity_paused_accessed_at  DateTime?
  inactivity_paused_access_count Int       @default(0)
  reactivation_review_required   Boolean   @default(false)
  created_at                     DateTime  @default(now())
  updated_at                     DateTime  @updatedAt

  nomade                   Nomade?
  // Lado reverso de "eu sou o principal desta organização" — no máximo 1 de
  // cada, aplicado em código (mesmo padrão do comentário em Project sobre
  // agency_id/company_id: "no máximo um dos dois preenchido").
  owned_agency             Agency?            @relation("AgencyOwner")
  owned_company            Company?           @relation("CompanyOwner")
  term_acceptances         TermAcceptance[]
  chat_participations      ChatParticipant[]
  sent_messages            ChatMessage[]      @relation("SentMessages")
  course_enrollments       CourseEnrollment[]
  lider_areas              LiderArea[]
  tasks_como_lider         ProjectTask[]      @relation("TaskLiderResponsavel")
  linked_coupons           Coupon[]
  created_clients          Client[]           @relation("ClientCreatedBy")
  created_projects         Project[]          @relation("ProjectCreatedBy")
  profile                  UserProfile?
  deleted_company_archives CompanyArchive[]   @relation("CompanyArchiveDeletedBy")

  @@map("users")
}

// Dados pessoais/endereço complementares — separados de User de propósito:
// User é lido em toda request autenticada (verifyToken) e não deve carregar
// campos raramente usados; CPF/RG/data de nascimento são PII sensível (LGPD),
// isolar numa tabela própria facilita auditoria/restrição de acesso depois.
// 1:1 com User, opcional — a maioria dos usuários não preenche isso ainda.
model UserProfile {
  id      String @id @default(cuid())
  user_id String @unique
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // Dados pessoais
  social_name String?
  birth_date  DateTime?
  gender      String?
  cpf         String?
  rg          String?

  // Contato adicional (além de User.email/phone)
  whatsapp        String?
  phone_secondary String?

  // Endereço
  zip_code     String?
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?
  country      String? @default("Brasil")

  // Notas administrativas — visíveis só pra admin/partner no frontend
  admin_notes    String? @db.LongText
  internal_notes String? @db.LongText

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("user_profiles")
}

model LiderArea {
  id                    String   @id @default(cuid())
  user_id               String
  user                  User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  area_nome             String
  categorias_permitidas String?  @db.LongText
  produtos_permitidos   String?  @db.LongText
  ativo                 Boolean  @default(true)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  @@map("lider_areas")
}

// ─── Companies (Empresas / Clientes) ─────────────────────────────────────────

model Company {
  id                                   String          @id @default(cuid())
  sequence_number                      Int             @unique @default(autoincrement())
  // Código de exibição sequencial (emp_00001, emp_00002, ...) — gerado a
  // partir de sequence_number. Nunca se repete (AUTO_INCREMENT no MySQL).
  name                                 String
  cnpj                                 String?         @unique
  email                                String?
  phone                                String?
  type                                 String          @default("empresa")
  // empresa | agencia | nomade | parceiro — classificação real do
  // relacionamento comercial (empresa direta, atendida por agência, por
  // nômade, ou trazida por um parceiro via referred_by_partner_id)
  status                               String          @default("ativo")
  // ativo | inativo | prospecto | inadimplente
  segment                              String?
  address                              String?         @db.LongText
  // Rua / Avenida — número/bairro/cidade/estado/CEP ficam em colunas
  // próprias abaixo (mesmo padrão do Client, ver schema.prisma dele).
  number                               String?
  neighborhood                         String?
  city                                 String?
  state                                String?
  zip_code                             String?
  pix_key                              String?
  pix_key_type                         String? // cpf | cnpj | email | phone | random
  description                          String?         @db.LongText
  logo                                 String?         @db.LongText
  website                              String?
  // ── Commercial contact ──────────────────────────────────────────
  commercial_contact_name              String?         @db.VarChar(255)
  commercial_contact_role              String?         @db.VarChar(100)
  commercial_contact_email             String?         @db.VarChar(255)
  commercial_contact_phone             String?         @db.VarChar(30)
  commercial_contact_whatsapp          String?         @db.VarChar(30)
  commercial_contact_preferred_channel String?         @db.VarChar(50)
  commercial_contact_notes             String?         @db.LongText
  // ── Financial contact ───────────────────────────────────────────
  financial_contact_name               String?         @db.VarChar(255)
  financial_contact_role               String?         @db.VarChar(100)
  financial_contact_email              String?         @db.VarChar(255)
  financial_contact_phone              String?         @db.VarChar(30)
  financial_contact_whatsapp           String?         @db.VarChar(30)
  financial_contact_preferred_channel  String?         @db.VarChar(50)
  financial_contact_notes              String?         @db.LongText
  financial_contact_user_id            String? // FK to User (optional link to financial user)
  use_master_as_financial_fallback     Boolean         @default(true)
  referred_by_partner_id               String? // FK to PartnerProfile (who referred this company)
  referred_by_partner                  PartnerProfile? @relation(fields: [referred_by_partner_id], references: [id], onDelete: SetNull)
  // Usuário principal — nullable porque, hoje, a maioria das Companies
  // existentes não tem nenhum usuário vinculado ainda (empresa "casca",
  // criada antes do primeiro company_admin). Toda Company nova criada pelo
  // fluxo atualizado sempre preenche isto; regra aplicada em código, não
  // em constraint de banco (mesmo padrão do resto do schema).
  owner_user_id                        String?         @unique
  owner                                User?           @relation("CompanyOwner", fields: [owner_user_id], references: [id])
  created_at                           DateTime        @default(now())
  updated_at                           DateTime        @updatedAt

  projects        Project[]              @relation("ProjectLegacyClient")
  projects_owned  Project[]              @relation("ProjectNewCompanyOwner")
  invoices        Invoice[]
  members         User[]                 @relation("CompanyMembers")
  payment_methods CompanyPaymentMethod[]
  squad_config    SquadConfig?
  coupon_usages   CouponUsage[]
  client_links    ClientLink[]

  @@map("companies")
}

// Snapshot histórico gravado sempre que uma Company é excluída — guarda os
// dados cadastrais completos e um resumo (usuários vinculados + o que foi
// feito com cada um, contagem de projetos/faturas) no momento da exclusão.
// O sequence_number correspondente é liberado (ver CompanyFreedSequence) e
// pode ser reaproveitado por uma Company nova no futuro; este registro é o
// jeito de ainda sabermos "quem foi o emp_N antigo" depois disso acontecer.
model CompanyArchive {
  id                  String   @id @default(cuid())
  sequence_number     Int
  original_company_id String
  name                String
  snapshot            String   @db.LongText // JSON completo dos campos da Company
  users_snapshot      String   @db.LongText // JSON: usuários vinculados + ação aplicada (deleted|unlinked|suspended)
  projects_count      Int      @default(0)
  invoices_count      Int      @default(0)
  deleted_by_user_id  String?
  deleted_by          User?    @relation("CompanyArchiveDeletedBy", fields: [deleted_by_user_id], references: [id], onDelete: SetNull)
  deleted_at          DateTime @default(now())

  @@index([sequence_number])
  @@map("company_archives")
}

// Pool de sequence_number liberados por exclusão de Company, disponíveis
// para reaproveitamento na criação da próxima Company (ver users.ts).
model CompanyFreedSequence {
  id              String   @id @default(cuid())
  sequence_number Int      @unique
  freed_at        DateTime @default(now())

  @@map("company_freed_sequences")
}

model CompanyPaymentMethod {
  id             String   @id @default(cuid())
  company_id     String
  company        Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  brand          String   @db.VarChar(20)
  last_four      String   @db.VarChar(4)
  expiry         String   @db.VarChar(7)
  holder_name    String   @db.VarChar(255)
  is_default     Boolean  @default(false)
  // is_client_card: true = cartão do cliente externo. Agência vê só last_four, holder_name mascarado
  is_client_card Boolean  @default(false)
  label          String?  @db.VarChar(100)
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@map("company_payment_methods")
}

// ─── Clients (entidade própria, separada de Company) ─────────────────────────
// Client é o cliente final (pessoa física ou jurídica) que uma Agency,
// Company ou Partner atende/indica. NÃO confundir com Company, que é a
// empresa contratante da Allka. O vínculo entre um Client e quem o atende
// é feito via ClientLink (nunca direto por FK aqui), porque o mesmo Client
// pode precisar estar ligado a mais de um perfil ao mesmo tempo.
model Client {
  id              String @id @default(cuid())
  sequence_number Int    @unique @default(autoincrement())

  name         String
  type         String  @default("pj")
  // pj | pf
  document     String? @unique
  // CNPJ (pj) ou CPF (pf) — único porque a tabela é nova, sem dado legado.
  email        String?
  phone        String?
  website      String?
  segment      String?
  status       String  @default("active")
  // active | inactive
  address      String?
  number       String?
  neighborhood String?
  city         String?
  state        String?
  zip_code     String?
  avatar       String? @db.LongText
  notes        String? @db.LongText
  description  String? @db.LongText

  created_by_user_id String?
  created_by_user    User?   @relation("ClientCreatedBy", fields: [created_by_user_id], references: [id], onDelete: SetNull)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  links ClientLink[]

  @@index([name])
  @@index([email])
  @@index([status])
  @@index([created_by_user_id])
  @@map("clients")
}

// Vínculo entre um Client e quem o atende (Agency, Company ou Partner).
// Exatamente um dos três campos (agency_id | company_id | partner_id) deve
// estar preenchido por linha — Prisma/MySQL não garante isso sozinho (não
// há CHECK constraint declarável no schema para "XOR" entre colunas); essa
// validação fica para o backend no próximo bloco (rota de criação/edição
// de vínculo), não é imposta pelo banco.
model ClientLink {
  id String @id @default(cuid())

  client_id String
  client    Client @relation(fields: [client_id], references: [id], onDelete: Cascade)

  agency_id String?
  agency    Agency? @relation(fields: [agency_id], references: [id], onDelete: Cascade)

  company_id String?
  company    Company? @relation(fields: [company_id], references: [id], onDelete: Cascade)

  partner_id String?
  partner    PartnerProfile? @relation(fields: [partner_id], references: [id], onDelete: Cascade)

  status     String   @default("active")
  // active | inactive
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([client_id, agency_id])
  @@unique([client_id, company_id])
  @@unique([client_id, partner_id])
  @@index([client_id])
  @@index([agency_id])
  @@index([company_id])
  @@index([partner_id])
  @@map("client_links")
}

// ─── Agencies ────────────────────────────────────────────────────────────────

model Agency {
  id             String   @id @default(cuid())
  // Coluna física continua "user_id" (@map) — só o campo Prisma vira
  // owner_user_id, pra refletir que é o usuário PRINCIPAL, não o único.
  // @unique mantido de propósito: 1 pessoa não pode ser dona de 2 agências
  // ao mesmo tempo. Quem deixa de ser 1:1 é o vínculo de membro (ver
  // User.agency_id / Agency.members abaixo), não a posse.
  owner_user_id  String   @unique @map("user_id")
  owner          User     @relation("AgencyOwner", fields: [owner_user_id], references: [id])
  members        User[]   @relation("AgencyMembers")
  // Numeração emp_N exibida no admin/empresas — nullable porque, ao
  // contrário de Company, não é atribuída automaticamente a toda Agency
  // nova; hoje é setada manualmente caso a caso (ver seed/scripts admin).
  sequence_number Int?    @unique
  name           String
  cnpj           String?  @unique
  email          String?
  phone          String?
  partner_level  String   @default("bronze")
  // bronze | silver | gold | platinum | diamond
  wallet_balance Float    @default(0)
  status         String   @default("ativo")
  address        String?
  number         String?
  neighborhood   String?
  city           String?
  state          String?
  zip_code       String?
  pix_key        String?
  pix_key_type   String? // cpf | cnpj | email | phone | random
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  match_queue_entry MatchQueueEntry?
  leaderships       AgencyLeadership[]
  reports           AgencyReport[]
  client_links      ClientLink[]
  projects_owned    Project[]
  // Presente só quando esta Agency foi convidada/virou Partner (ver
  // PartnerProfile acima) — nullable, a maioria das agências nunca tem um.
  partner_profile   PartnerProfile?

  @@map("agencies")
}

// ─── Nômades ─────────────────────────────────────────────────────────────────

model Nomade {
  id                         String    @id @default(cuid())
  user_id                    String?   @unique
  user                       User?     @relation(fields: [user_id], references: [id])
  name                       String
  email                      String    @unique
  whatsapp                   String?
  // Exigido pra prestar serviços pra nós — nômade precisa ter CNPJ válido
  // (pessoa jurídica ou MEI) mesmo sendo cadastrado como pessoa física na
  // plataforma. Nullable no banco (dados legados antes desta regra), mas
  // obrigatório na validação de criação (ver POST /api/users em users.ts).
  cnpj                       String?   @unique
  avatar                     String?   @db.LongText
  level                      String    @default("bronze")
  // bronze | silver | gold | platinum | diamond | leader
  status                     String    @default("aguardando_aprovacao")
  // ativo | inativo | aguardando_aprovacao | reprovado | pausado
  address                    String?
  number                     String?
  neighborhood               String?
  city                       String?
  state                      String?
  zip_code                   String?
  pix_key                    String?
  pix_key_type               String? // cpf | email | phone | random
  score                      Int       @default(0)
  tasks_completed_quarter    Int       @default(0)
  tasks_completed_total      Int       @default(0)
  areas_of_interest          String?   @db.LongText
  // JSON: string[]
  registration_date          DateTime  @default(now())
  last_access                DateTime?
  terms_accepted             Boolean   @default(false)
  is_leader                  Boolean   @default(false)
  leader_id                  String?
  min_monthly_goal           Float?
  performance_avg_rating     Float     @default(0)
  performance_on_time        Float     @default(0)
  performance_rejection_rate Float     @default(0)
  created_at                 DateTime  @default(now())
  updated_at                 DateTime  @updatedAt

  qualifications      Qualification[]
  wallet_transactions WalletTransaction[]
  bank_account        BankAccount?
  task_executions     TaskExecution[]
  withdrawal_requests WithdrawalRequest[]
  habilidades         NomadeHabilidade[]

  @@map("nomades")
}

// ─── NomadeHabilidade ────────────────────────────────────────────────────────
// Vínculo estruturado entre nômade e área/categoria/produto para seleção automática.
// Complementa o modelo Qualification (mantido para compatibilidade).

model NomadeHabilidade {
  id        String @id @default(cuid())
  nomade_id String @db.VarChar(30)
  nomade    Nomade @relation(fields: [nomade_id], references: [id], onDelete: Cascade)

  area String @db.VarChar(50)
  // Performance | Design | Conteúdo | Web | Audiovisual

  categoria_produto String? @db.VarChar(100)
  // Categoria do produto, e.g., "Performance e Anúncios Patrocinados"

  produto_id String? @db.VarChar(30)
  // Produto específico (opcional) — link suave, sem FK forçada para evitar cascata

  modelo_tarefa_id String? @db.VarChar(30)
  // CatalogTask específica (opcional) — link suave

  nota_media      Float  @default(0)
  disponibilidade String @default("disponivel")
  // disponivel | indisponivel | pausado

  ativo      Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([nomade_id, area, categoria_produto, produto_id, modelo_tarefa_id])
  @@map("nomade_habilidades")
}

model NomadeLevel {
  id           String   @id @default(cuid())
  slug         String   @unique
  // bronze | silver | gold | platinum | diamond | leader
  name         String
  min_score    Int
  max_score    Int?
  color        String?
  icon         String?
  benefits     String?  @db.LongText
  // JSON: string[]
  requirements String?  @db.LongText
  // JSON: { label: string, value: string }[]
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("nomade_levels")
}

model PartnerLevel {
  id                     String   @id @default(cuid())
  name                   String   @unique
  description            String?  @db.LongText
  icon                   String?
  color                  String?
  gradient               String?
  min_mrr                Int      @default(0)
  max_mrr                Int?
  led_agencies_min       Int      @default(0)
  led_agencies_mrr_min   Int      @default(0)
  premium_project_limit  Int?
  commission_rate        Float    @default(0)
  extra_discount         Float    @default(0)
  receives_leads_premium Boolean  @default(false)
  requires_partner       Boolean  @default(false)
  level_up_bonus_credits Int      @default(0)
  benefits               String?  @db.LongText
  // JSON: string[]
  sort_order             Int      @default(0)
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  @@map("partner_levels")
}

model Qualification {
  id                 String    @id @default(cuid())
  nomade_id          String
  nomade             Nomade    @relation(fields: [nomade_id], references: [id])
  category           String
  task               String
  status             String    @default("teste_pendente")
  // habilitado | pausado | teste_pendente | reprovado
  certification_date DateTime?
  paused_date        DateTime?
  test_required      Boolean   @default(true)
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  @@map("qualifications")
}

model WalletTransaction {
  id            String   @id @default(cuid())
  nomade_id     String
  nomade        Nomade   @relation(fields: [nomade_id], references: [id])
  type          String
  // credit | debit | bonus | penalty | withdrawal
  amount        Float
  description   String   @db.LongText
  date          DateTime @default(now())
  receipt       String?  @db.LongText
  justification String?  @db.LongText

  @@map("wallet_transactions")
}

model BankAccount {
  id           String   @id @default(cuid())
  nomade_id    String   @unique
  nomade       Nomade   @relation(fields: [nomade_id], references: [id])
  bank         String
  agency       String
  account      String
  account_type String   @default("corrente")
  // corrente | poupanca
  cnpj         String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("bank_accounts")
}

// ─── Projects & Tasks ─────────────────────────────────────────────────────────

model Project {
  id                   String          @id @default(cuid())
  title                String
  description          String?         @db.LongText
  client_id            String?
  client               Company?        @relation("ProjectLegacyClient", fields: [client_id], references: [id])
  // ── Novo escopo estruturado (adicional ao legado acima; não usado pelos
  // projetos existentes, que continuam funcionando só por agency/client_id) ──
  // No máximo um dos três deve estar preenchido — regra aplicada em código,
  // não em constraint de banco (mesmo padrão do ClientLink).
  agency_id            String?
  agency_owner         Agency?         @relation(fields: [agency_id], references: [id], onDelete: SetNull)
  company_id           String?
  company_owner        Company?        @relation("ProjectNewCompanyOwner", fields: [company_id], references: [id], onDelete: SetNull)
  partner_id           String?
  partner_owner        PartnerProfile? @relation(fields: [partner_id], references: [id], onDelete: SetNull)
  // Autoria real do projeto — sempre resolvida pelo backend a partir do
  // token autenticado (nunca aceita do payload). Distinta do ownership
  // organizacional acima (agency_id/company_id/partner_id), que continua
  // sendo o filtro usado para escopo de listagem. Nullable só porque os 3
  // fixtures "sem vínculo" do seed local são inseridos direto pelo script,
  // sem passar pela API — todo projeto real criado via POST /api/projects
  // sempre tem isto preenchido.
  created_by_user_id   String?
  created_by           User?           @relation("ProjectCreatedBy", fields: [created_by_user_id], references: [id], onDelete: SetNull)
  // Código público sequencial e persistente (proj_00001, proj_00002, ...).
  // Obrigatório desde a fase 2 da migration (depois do backfill dos
  // projetos existentes) — toda linha nova recebe um valor via
  // getNextSequenceValue(tx, "project") — ver src/lib/sequence.ts.
  project_code         String          @unique
  status               String          @default("draft")
  // draft | negotiation | awaiting-payment | planning | in-progress | paused | completed | cancelled | paid
  // draft | negotiation | awaiting-payment | planning | in-progress | paused | completed | cancelled
  lifecycle            String          @default("avulso")
  // avulso | mensal
  type                 String?
  // Marketing Digital | Desenvolvimento Web | Design | E-commerce | Desenvolvimento Mobile | Consultoria
  value                Float           @default(0)
  budget               Float           @default(0)
  spent                Float           @default(0)
  progress             Int             @default(0)
  agency               String?
  company_type         String?
  // company | agency | nomad
  consultant           String?
  consultant_email     String?
  team_size            Int             @default(0)
  nomades              String?         @db.LongText
  // JSON: string[]
  bitrix_sync          Boolean         @default(false)
  portfolio_permission Boolean         @default(false)
  overdue              Boolean         @default(false)
  from_lead            Boolean         @default(false)
  billing_day          Int?
  billing_start_date   String?
  start_date           DateTime?
  end_date             DateTime?
  created_at           DateTime        @default(now())
  updated_at           DateTime        @updatedAt

  task_executions TaskExecution[]
  invoices        Invoice[]
  products        ProjectProduct[]
  project_tasks   ProjectTask[]
  payments        Payment[]
  credentials     ProjectCredential[]

  @@index([created_by_user_id])
  @@map("projects")
}

// ─── EntitySequence — contador atômico e seguro para códigos sequenciais ────
// Usado para gerar project_code (proj_00001) e ProjectTask.task_code
// (T000001) sem depender de SELECT MAX()+1 nem de ranking de consulta.
// O incremento é feito via UPDATE ... SET current_value = LAST_INSERT_ID(
// current_value + 1) dentro da transação chamadora — idioma padrão do MySQL
// para sequências customizadas, atômico sob concorrência (ver
// src/lib/sequence.ts).
model EntitySequence {
  id            String   @id @default(cuid())
  key           String   @unique
  current_value Int      @default(0)
  updated_at    DateTime @updatedAt

  @@map("entity_sequences")
}

model Specialty {
  id              String   @id @default(cuid())
  name            String
  description     String?  @db.LongText
  hourly_rate     Float    @default(0)
  category        String
  required_skills String?  @db.LongText
  // JSON: string[]
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  task_templates TaskTemplate[]

  @@map("specialties")
}

model TaskTemplate {
  id                   String     @id @default(cuid())
  name                 String
  description          String?    @db.LongText
  specialty_id         String?
  specialty            Specialty? @relation(fields: [specialty_id], references: [id])
  base_price           Float      @default(0)
  complexity           String     @default("basic")
  // basic | intermediate | advanced | premium
  category             String?
  tags                 String?    @db.LongText
  // JSON: string[]
  estimated_hours      Float      @default(1)
  profit_margin        Float      @default(30)
  emergency_multiplier Float      @default(1.5)
  is_active            Boolean    @default(true)
  created_at           DateTime   @default(now())
  updated_at           DateTime   @updatedAt

  executions TaskExecution[]

  @@map("task_templates")
}

model TaskExecution {
  id           String        @id @default(cuid())
  project_id   String?
  project      Project?      @relation(fields: [project_id], references: [id])
  template_id  String?
  template     TaskTemplate? @relation(fields: [template_id], references: [id])
  nomade_id    String?
  nomade       Nomade?       @relation(fields: [nomade_id], references: [id])
  title        String
  description  String?       @db.LongText
  status       String        @default("draft")
  // draft | launched | in_progress | returned | paused | agency_approval | client_approval | approved | rejected | expired
  priority     String        @default("medium")
  // low | medium | high | urgent
  type         String        @default("standard")
  // standard | qualification | learning
  due_date     DateTime?
  delivered_at DateTime?
  approved_at  DateTime?
  rating       Float?
  feedback     String?       @db.LongText
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt

  @@map("task_executions")
}

// ─── Products ─────────────────────────────────────────────────────────────────

model Product {
  id                String   @id @default(cuid())
  name              String
  description       String?  @db.LongText
  // Sem @db.VarChar explícito, o Prisma aplicava o padrão de 191 chars pro
  // MySQL — curto demais pro conteúdo real (ex.: PA0003 tem 251 chars, texto
  // legítimo, não lixo de dado). Ampliado com folga; continua VarChar (não
  // Text) porque o campo é conceitualmente "curto" — só a coluna estava
  // subdimensionada. Ver migration 20260711100400_widen_short_description.
  short_description String?  @db.VarChar(500)
  category          String
  tags              String?  @db.LongText
  // JSON: string[]
  base_price        Float    @default(0)
  complexity        String   @default("basic")
  // basic | intermediate | advanced | premium
  visibility        String   @default("{\"company\":true,\"agency\":true,\"partner\":false,\"inHouse\":false}")
  // JSON: ProductVisibility
  image             String?  @db.LongText
  demonstrations    String?  @db.LongText
  // JSON: string[]
  contract_count    Int      @default(0)
  average_rating    Float    @default(0)
  completion_time   String?
  is_active         Boolean  @default(true)
  metadata          String?  @db.LongText
  // JSON: extras do frontend (tasks, recurrence, summaryDescription, pricing calc, etc.)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  variations       ProductVariation[]
  addons           ProductAddon[]
  task_links       ProductCatalogTask[]
  project_products ProjectProduct[]
  project_tasks    ProjectTask[]
  payment_items    PaymentItem[]

  @@map("products")
}

model ProductVariation {
  id                String    @id @default(cuid())
  product_id        String
  product           Product   @relation(fields: [product_id], references: [id], onDelete: Cascade)
  name              String
  // ex: "Até 2 campanhas"
  description       String?   @db.LongText
  // descrição complementar da variação
  price             Float     @default(0)
  // preço absoluto desta variação
  price_modifier    Float     @default(0)
  // modificador relativo sobre o preço base (legado/alternativo)
  deadline_days     Int?
  // prazo de entrega em dias corridos
  scope_description String?   @db.LongText
  // descrição do escopo/quantidade desta variação
  features          String?   @db.LongText
  // JSON: string[] — bullet points do que inclui/muda nesta variação
  sort_order        Int       @default(0)
  is_active         Boolean   @default(true)
  created_at        DateTime  @default(now())
  updated_at        DateTime? @updatedAt
  // nullable: SQLite ALTER TABLE ADD COLUMN não suporta NOT NULL sem DEFAULT literal

  project_products ProjectProduct[]

  @@map("product_variations")
}

model ProductAddon {
  id          String   @id @default(cuid())
  product_id  String
  product     Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  name        String
  description String?  @db.LongText
  price       Float    @default(0)
  category    String?
  created_at  DateTime @default(now())

  @@map("product_addons")
}

// ─── Catalog Tasks (Cadastro de Tarefas) ─────────────────────────────────────

model CatalogTask {
  id          String  @id @default(cuid())
  code        String  @unique
  // ex: "CT-001", gerado automaticamente
  name        String
  category    String
  // ex: "Design e Criação" | "Performance" | "Estratégia"
  subcategory String?
  task_type   String  @default("execution")
  // execution | review | approval | qualification | support
  description String? @db.LongText
  objective   String? @db.LongText

  // Execution config
  default_deadline_days Int?
  default_priority      String  @default("medium")
  // low | medium | high | urgent
  complexity            String  @default("basic")
  // basic | intermediate | advanced | premium
  estimated_hours       Float?
  responsible_type      String?
  // ex: "nomad" | "leader" | "internal"
  requires_access       Boolean @default(false)
  requires_briefing     Boolean @default(false)
  requires_files        Boolean @default(false)

  // Rich content (JSON fields)
  steps              String? @db.LongText
  // JSON: TaskStep[]
  checklist          String? @db.LongText
  // JSON: ChecklistItem[]
  briefing_questions String? @db.LongText
  // JSON: BriefingQuestion[]
  required_files     String? @db.LongText
  // JSON: string[]
  execution_rules    String? @db.LongText
  // JSON: string[]
  conclusion_rules   String? @db.LongText
  internal_guidance  String? @db.LongText

  // Status
  status    String  @default("ativa")
  // ativa | inativa | em_revisao
  is_active Boolean @default(true)
  notes     String? @db.LongText
  // internal observations

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  product_links ProductCatalogTask[]
  project_tasks ProjectTask[]

  @@map("catalog_tasks")
}

// ─── Product ↔ CatalogTask (many-to-many join) ───────────────────────────────

model ProductCatalogTask {
  id              String @id @default(cuid())
  product_id      String
  catalog_task_id String

  product      Product     @relation(fields: [product_id], references: [id], onDelete: Cascade)
  catalog_task CatalogTask @relation(fields: [catalog_task_id], references: [id], onDelete: Cascade)

  // Link-specific overrides
  sort_order   Int     @default(0)
  is_mandatory Boolean @default(true)
  phase        String?
  // ex: "E01", "E02" — etapa do produto onde esta tarefa entra
  notes        String? @db.LongText
  // observação específica deste produto

  created_at DateTime @default(now())

  @@unique([product_id, catalog_task_id])
  @@map("product_catalog_tasks")
}

// ─── ProjectProduct — Product linked to a Project ────────────────────────────

model ProjectProduct {
  id           String            @id @default(cuid())
  project_id   String
  project      Project           @relation(fields: [project_id], references: [id], onDelete: Cascade)
  product_id   String
  product      Product           @relation(fields: [product_id], references: [id])
  variation_id String?
  variation    ProductVariation? @relation(fields: [variation_id], references: [id])

  // Snapshot: preserves commercial history even if product is later edited
  product_name_snapshot     String
  product_code_snapshot     String?
  product_category_snapshot String
  product_price_snapshot    Float   @default(0)
  recurrence_snapshot       String?
  // avulso | mensal

  // Commercial snapshot (filled by the front-end at link time)
  preco_final_cliente_snapshot Float  @default(0)
  comissao_snapshot            Float  @default(0)
  pagador_snapshot             String @default("AGENCIA")
  // AGENCIA | CLIENTE

  // Status
  status            String    @default("PENDENTE")
  // PENDENTE | EM_EXECUCAO | CONCLUIDO | CANCELADO
  start_date        DateTime?
  expected_end_date DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tasks         ProjectTask[]
  credentials   ProjectCredential[]
  payment_items PaymentItem[]

  @@unique([project_id, product_id])
  @@map("project_products")
}

// ─── ProjectTask — Execution task generated from a CatalogTask ───────────────

model ProjectTask {
  id                 String         @id @default(cuid())
  project_id         String
  project            Project        @relation(fields: [project_id], references: [id], onDelete: Cascade)
  project_product_id String
  project_product    ProjectProduct @relation(fields: [project_product_id], references: [id], onDelete: Cascade)
  product_id         String
  product            Product        @relation(fields: [product_id], references: [id])
  catalog_task_id    String?
  catalog_task       CatalogTask?   @relation(fields: [catalog_task_id], references: [id])

  // Snapshots: task model data at the time of creation
  code_snapshot     String?
  name_snapshot     String
  category_snapshot String?

  // Globally unique operational task code — T000001, T000002, …
  task_code String? @unique

  // ── Origem da geração (preenchidos só em tarefas nascidas de pagamento
  // confirmado — ver src/lib/confirm-payment.ts). project_id/project_product_id/
  // product_id/catalog_task_id acima já respondem "qual projeto/produto/
  // template originou"; os campos abaixo cobrem o que ainda faltava: qual
  // pagamento e qual ciclo, e a chave que impede duplicar a mesma tarefa. ──
  origin_payment_id String?
  origin_payment    Payment? @relation("PaymentGeneratedTasks", fields: [origin_payment_id], references: [id], onDelete: SetNull)
  // paymentId:projectProductId:catalogTaskId:occurrenceIndex — impede
  // recriar a mesma tarefa do mesmo produto/pagamento/ciclo/ocorrência.
  generation_key    String?  @unique
  // Espelha Payment.billing_cycle_key no momento da geração (fica preservado
  // mesmo se o Payment for editado depois).
  billing_cycle_key String?
  // Reservado para produtos que no futuro gerem mais de uma ocorrência da
  // mesma tarefa numa única geração (ex.: "3x" do mesmo item). Sempre 0
  // nesta fase — não há hoje quantidade contratada por ProjectProduct.
  occurrence_index  Int      @default(0)

  // Task fields
  title                  String
  description            String? @db.LongText
  status                 String  @default("PARA_LANCAMENTO")
  // PARA_LANCAMENTO | EM_LANCAMENTO | AGUARDANDO_INFORMACOES | LIBERADA_PARA_EXECUCAO
  // | EM_EXECUCAO | EM_REVISAO | EM_APROVACAO | CONCLUIDA | CANCELADA | AGUARDANDO_NOMADE
  priority               String  @default("medium")
  // low | medium | high | urgent
  assignee_id            String?
  responsavel_agencia_id String?
  nomade_responsavel_id  String?
  lider_responsavel_id   String?
  // User.id of the leader assigned to qualify this task

  due_date                DateTime?
  start_date              DateTime?
  completed_at            DateTime?
  data_lancamento         DateTime?
  data_liberacao_execucao DateTime?
  data_inicio_execucao    DateTime?
  data_conclusao          DateTime?
  // Prazo de 30 dias para lançar a tarefa — após esta data ela expira automaticamente
  lancamento_expires_at   DateTime?

  sort_order Int     @default(0)
  fase       String?
  // kept for backward compat
  phase      String?

  // JSON snapshots (preserve checklist/steps/briefing from model at time of creation)
  checklist_snapshot String? @db.LongText
  steps_snapshot     String? @db.LongText
  briefing_snapshot  String? @db.LongText
  observations       String? @db.LongText

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  stages             ProjectTaskStage[]
  briefing_answers   TaskBriefingAnswer[]
  attachments        TaskAttachment[]
  assignment_history TaskAssignmentHistory[]
  credentials        ProjectCredential[]
  lider_responsavel  User?                   @relation("TaskLiderResponsavel", fields: [lider_responsavel_id], references: [id])

  @@index([origin_payment_id])
  @@map("project_tasks")
}

// ─── ProjectTaskStage ─────────────────────────────────────────────────────

model ProjectTaskStage {
  id              String      @id @default(cuid())
  project_task_id String
  project_task    ProjectTask @relation(fields: [project_task_id], references: [id], onDelete: Cascade)

  catalog_step_ref          String?
  // reference code from the source CatalogTask step JSON
  // Chave estável de origem pra etapas geradas por especificação (ver
  // src/lib/generate-tasks-from-spec.ts) — formato
  // "spec:{generationKey}:stage:{stageCode}". Permite reencontrar a MESMA
  // etapa em reexecuções (create-only, nunca apaga) sem depender do id
  // interno. Nula pras etapas do gerador genérico por catálogo, que não
  // precisam desse rastreio (idempotência já garantida por generation_key
  // na ProjectTask pai).
  source_key                String?
  titulo                    String
  descricao                 String? @db.LongText
  ordem                     Int     @default(0)
  status                    String  @default("PENDENTE")
  // PENDENTE | EM_ANDAMENTO | CONCLUIDA | BLOQUEADA
  obrigatoria               Boolean @default(true)
  depende_da_etapa_anterior Boolean @default(true)
  briefing_necessario       Boolean @default(false)
  checklist_snapshot        String? @db.LongText
  // JSON: ChecklistItem[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([project_task_id, source_key])
  @@map("project_task_stages")
}

// ─── TaskBriefingAnswer ──────────────────────────────────────────────────

model TaskBriefingAnswer {
  id              String      @id @default(cuid())
  project_task_id String
  project_task    ProjectTask @relation(fields: [project_task_id], references: [id], onDelete: Cascade)

  question_key  String
  // matches the key from briefing_snapshot JSON
  question_text String  @db.LongText
  answer        String? @db.LongText
  files         String? @db.LongText
  // JSON: { name, url, size, mime_type }[]
  links         String? @db.LongText
  // JSON: string[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([project_task_id, question_key])
  @@map("task_briefing_answers")
}

// ─── TaskAttachment ──────────────────────────────────────────────────────────

model TaskAttachment {
  id              String      @id @default(cuid())
  project_task_id String
  project_task    ProjectTask @relation(fields: [project_task_id], references: [id], onDelete: Cascade)

  type         String  @default("file")
  // file | link | reference | delivery
  name         String
  url          String  @db.LongText
  size         Int?
  // bytes
  mime_type    String? @db.LongText
  observations String? @db.LongText
  uploaded_by  String?
  // user id or name

  created_at DateTime @default(now())

  @@map("task_attachments")
}

// ─── TaskAssignmentHistory ────────────────────────────────────────────────────

model TaskAssignmentHistory {
  id              String      @id @default(cuid())
  project_task_id String
  project_task    ProjectTask @relation(fields: [project_task_id], references: [id], onDelete: Cascade)

  nomade_id   String?
  // null when no nomad was found
  criterio    String
  // "nota_media" | "manual"
  nota_nomade Float?
  automatico  Boolean @default(true)
  resultado   String
  // "atribuido" | "sem_nomade_disponivel"
  detalhes    String? @db.LongText
  // JSON: extra info (eligible candidates, rejection reason, etc.)

  created_at DateTime @default(now())

  @@map("task_assignment_history")
}

// ─── SystemAlert ──────────────────────────────────────────────────────────────

model SystemAlert {
  id          String    @id @default(cuid())
  type        String
  // "nomade_nao_encontrado" | "tarefa_atrasada" | etc.
  title       String
  message     String    @db.LongText
  severity    String    @default("warning")
  // "info" | "warning" | "error"
  entity_type String?
  // "project_task" | "project" | etc.
  entity_id   String?
  is_read     Boolean   @default(false)
  read_at     DateTime?
  created_at  DateTime  @default(now())

  @@map("system_alerts")
}

// ─── Financial ────────────────────────────────────────────────────────────────

model Invoice {
  id             String    @id @default(cuid())
  company_id     String?
  company        Company?  @relation(fields: [company_id], references: [id])
  project_id     String?
  project        Project?  @relation(fields: [project_id], references: [id])
  amount         Float
  status         String    @default("pending")
  // pending | paid | overdue | cancelled
  due_date       DateTime?
  paid_at        DateTime?
  description    String?   @db.LongText
  invoice_number String?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  @@map("invoices")
}

model WithdrawalRequest {
  id            String    @id @default(cuid())
  nomade_id     String
  nomade        Nomade    @relation(fields: [nomade_id], references: [id])
  amount        Float
  status        String    @default("aguardando_analise")
  // aguardando_analise | pagamento_agendado | pagamento_efetuado | cancelado | reprovado
  pix_key       String?
  pix_key_type  String?
  // cpf | email | phone | random
  notes         String?   @db.LongText
  reviewed_by   String?
  reviewed_at   DateTime?
  scheduled_for DateTime?
  paid_at       DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  @@map("withdrawal_requests")
}

// ─── Terms ────────────────────────────────────────────────────────────────────

model Term {
  id                   String   @id @default(cuid())
  title                String
  content              String   @db.LongText
  version              String
  acceptance_level     String   @default("usuario")
  // empresa | usuario
  target_account_types String?  @db.LongText
  // JSON: string[]
  is_active            Boolean  @default(true)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  acceptances TermAcceptance[]

  @@map("terms")
}

model TermAcceptance {
  id          String   @id @default(cuid())
  term_id     String
  term        Term     @relation(fields: [term_id], references: [id])
  user_id     String
  user        User     @relation(fields: [user_id], references: [id])
  accepted_at DateTime @default(now())
  ip_address  String?

  @@unique([term_id, user_id])
  @@map("term_acceptances")
}

// ─── Chat ─────────────────────────────────────────────────────────────────────

model Conversation {
  id         String   @id @default(cuid())
  title      String?
  type       String   @default("direct")
  // direct | group | support
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  participants ChatParticipant[]
  messages     ChatMessage[]

  @@map("conversations")
}

model ChatParticipant {
  id              String       @id @default(cuid())
  conversation_id String
  conversation    Conversation @relation(fields: [conversation_id], references: [id])
  user_id         String
  user            User         @relation(fields: [user_id], references: [id])
  role            String       @default("member")
  joined_at       DateTime     @default(now())

  @@unique([conversation_id, user_id])
  @@map("chat_participants")
}

model ChatMessage {
  id              String       @id @default(cuid())
  conversation_id String
  conversation    Conversation @relation(fields: [conversation_id], references: [id])
  sender_id       String
  sender          User         @relation("SentMessages", fields: [sender_id], references: [id])
  content         String       @db.LongText
  is_read         Boolean      @default(false)
  created_at      DateTime     @default(now())

  @@map("chat_messages")
}

// ─── Allkademy ────────────────────────────────────────────────────────────────

model Course {
  id                String   @id @default(cuid())
  title             String
  description       String?  @db.LongText
  category          String
  thumbnail         String?  @db.LongText
  duration          Int?
  is_published      Boolean  @default(false)
  is_free           Boolean  @default(true)
  // Público-alvo do curso: lista separada por vírgula de valores dentre
  // "all" | "company" | "agency" | "nomades" | "leader" | "partner".
  // "all" libera o curso para qualquer perfil. Default "all" preserva o
  // comportamento atual (visível a todos) para cursos já existentes.
  audience_profiles String   @default("all")
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  modules     CourseModule[]
  enrollments CourseEnrollment[]

  @@map("courses")
}

model CourseModule {
  id         String   @id @default(cuid())
  course_id  String
  course     Course   @relation(fields: [course_id], references: [id], onDelete: Cascade)
  title      String
  order      Int      @default(0)
  created_at DateTime @default(now())

  lessons Lesson[]

  @@map("course_modules")
}

model Lesson {
  id           String       @id @default(cuid())
  module_id    String
  module       CourseModule @relation(fields: [module_id], references: [id], onDelete: Cascade)
  title        String
  content_type String       @default("video")
  // video | text | quiz
  content_url  String?      @db.LongText
  duration     Int?
  order        Int          @default(0)
  created_at   DateTime     @default(now())

  @@map("lessons")
}

model CourseEnrollment {
  id           String    @id @default(cuid())
  course_id    String
  course       Course    @relation(fields: [course_id], references: [id])
  user_id      String
  user         User      @relation(fields: [user_id], references: [id])
  enrolled_at  DateTime  @default(now())
  progress     Float     @default(0)
  completed_at DateTime?

  @@unique([course_id, user_id])
  @@map("course_enrollments")
}

// ─── Admin ────────────────────────────────────────────────────────────────────

model AdminProfile {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.LongText
  is_master   Boolean  @default(false)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  permissions AdminPermission[]

  @@map("admin_profiles")
}

model AdminPermission {
  id         String       @id @default(cuid())
  profile_id String
  profile    AdminProfile @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  module     String
  action     String
  // view | edit | create | delete | not_applicable
  resource   String?      @db.LongText
  created_at DateTime     @default(now())

  @@unique([profile_id, module, action])
  @@map("admin_permissions")
}

// ─── Partners & Campaigns ─────────────────────────────────────────────────────

// Partner NÃO é um tipo de conta separado — é um upgrade que uma Agency já
// existente recebe (convite do admin, aceito pela própria Agency). Por isso
// esta entidade é 1:1 com Agency (agency_id), não com User: o mesmo usuário
// da Agency continua logando normalmente, só ganha acesso extra quando
// status = "active". Todas as relações financeiras/comissão/liderança
// abaixo (PartnerCommission, AgencyLeadership, AgencyReport, etc.)
// continuam apontando pro id desta entidade sem nenhuma mudança — só a
// âncora de identidade (era User, agora é Agency) mudou.
model PartnerProfile {
  id                 String    @id @default(cuid())
  agency_id          String    @unique
  agency             Agency    @relation(fields: [agency_id], references: [id], onDelete: Cascade)
  balance            Float     @default(0)
  total_earned       Float     @default(0)
  total_withdrawn    Float     @default(0)
  referral_link      String?
  referral_code      String?   @unique
  status             String    @default("invited")
  // invited | active | declined | suspended — ciclo de vida do convite:
  // admin convida (invited) -> Agency aceita (active) ou recusa (declined);
  // suspended é uma ação administrativa posterior, não parte do convite.
  invited_at         DateTime?
  responded_at       DateTime?
  pix_key            String?
  pix_key_type       String?
  // cpf | email | phone | random
  address            String?
  number             String?
  neighborhood       String?
  city               String?
  state              String?
  zip_code           String?
  linked_campaign_id String?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  commissions        PartnerCommission[]
  led_agencies       AgencyLeadership[]
  agency_reports     AgencyReport[]
  referred_companies Company[]
  withdrawals        PartnerWithdrawal[]
  client_links       ClientLink[]
  projects_owned     Project[]

  @@map("partner_profiles")
}

// Solicitação de saque do Partner — separado de WithdrawalRequest, que é
// exclusivo do fluxo de Nômade (payload/model diferentes: nomade_id vs
// partner_profile_id). Saldo (PartnerProfile.balance) só é debitado quando
// a solicitação é efetivamente processada (status="paid"); ainda não existe
// endpoint/tela admin para aprovar, então toda solicitação fica "pending".
model PartnerWithdrawal {
  id                 String         @id @default(cuid())
  partner_profile_id String
  partner            PartnerProfile @relation(fields: [partner_profile_id], references: [id])
  amount             Float
  pix_key            String
  pix_key_type       String
  // cpf | email | phone | random
  status             String         @default("pending")
  // pending | approved | rejected | paid | cancelled
  notes              String?        @db.LongText
  reviewed_by        String?
  reviewed_at        DateTime?
  requested_at       DateTime       @default(now())
  // processed_at é preenchido especificamente quando status="paid" (momento
  // em que o saldo do Partner é debitado). reviewed_at cobre qualquer
  // decisão do admin (aprovar/reprovar/pagar/cancelar).
  processed_at       DateTime?
  created_at         DateTime       @default(now())
  updated_at         DateTime       @updatedAt

  @@index([partner_profile_id])
  @@map("partner_withdrawals")
}

model Campaign {
  id               String    @id @default(cuid())
  name             String
  type             String    @default("coupon")
  // coupon | link | referral
  status           String    @default("active")
  // active | paused | ended
  commission_type  String    @default("percentage")
  // percentage | fixed
  commission_value Float     @default(10)
  coupon_code      String?   @unique
  start_date       DateTime?
  end_date         DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  commissions PartnerCommission[]

  @@map("campaigns")
}

model Coupon {
  id                           String    @id @default(cuid())
  code                         String    @unique
  coupon_type                  String    @default("discount")
  // discount | credit-bonus | referral
  discount_type                String    @default("percentage")
  // percentage | fixed
  discount_value               Float     @default(0)
  credit_bonus                 Float     @default(0)
  usage_limit                  Int       @default(0)
  // 0 = unlimited total uses
  usage_limit_per_company      String    @default("unlimited")
  // unlimited | once | custom
  max_uses_per_company         Int       @default(0)
  valid_from                   DateTime?
  valid_until                  DateTime?
  applicable_products          String?   @db.LongText
  // JSON: string[]
  allowed_account_types        String?   @db.LongText
  // JSON: ("empresas" | "agencias" | "nomades")[]
  allowed_company_ids          String?   @db.LongText
  // JSON: string[]
  allowed_user_ids             String?   @db.LongText
  // JSON: string[]
  linked_user_id               String?
  linked_user                  User?     @relation(fields: [linked_user_id], references: [id])
  linked_user_commission_type  String?
  // percentage | fixed
  linked_user_commission_value Float?
  status                       String    @default("active")
  // active | disabled | expired
  created_at                   DateTime  @default(now())
  updated_at                   DateTime  @updatedAt

  usages CouponUsage[]

  @@map("coupons")
}

model CouponUsage {
  id         String   @id @default(cuid())
  coupon_id  String
  coupon     Coupon   @relation(fields: [coupon_id], references: [id], onDelete: Cascade)
  company_id String?
  company    Company? @relation(fields: [company_id], references: [id])
  used_at    DateTime @default(now())

  @@map("coupon_usages")
}

model PartnerCommission {
  id           String         @id @default(cuid())
  partner_id   String
  partner      PartnerProfile @relation(fields: [partner_id], references: [id])
  campaign_id  String?
  campaign     Campaign?      @relation(fields: [campaign_id], references: [id])
  amount       Float
  status       String         @default("pending")
  // pending | approved | paid
  company_name String?
  project_name String?
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt

  @@map("partner_commissions")
}

// ─── Agency Leadership & Reports ─────────────────────────────────────────────

model AgencyLeadership {
  id         String         @id @default(cuid())
  partner_id String
  partner    PartnerProfile @relation(fields: [partner_id], references: [id], onDelete: Cascade)
  agency_id  String
  agency     Agency         @relation(fields: [agency_id], references: [id], onDelete: Cascade)
  status     String         @default("active")
  // active | paused | ended
  notes      String?        @db.LongText
  started_at DateTime       @default(now())
  ended_at   DateTime?
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt

  @@unique([partner_id, agency_id])
  @@map("agency_leaderships")
}

model AgencyReport {
  id             String         @id @default(cuid())
  partner_id     String
  partner        PartnerProfile @relation(fields: [partner_id], references: [id], onDelete: Cascade)
  agency_id      String
  agency         Agency         @relation(fields: [agency_id], references: [id], onDelete: Cascade)
  title          String         @db.VarChar(255)
  content        String         @db.LongText
  period_month   Int
  // 1-12
  period_year    Int
  rating         Int?
  // 1-5 stars
  highlights     String?        @db.LongText
  // JSON: string[]
  improvements   String?        @db.LongText
  // JSON: string[]
  mrr            Float?
  projects_count Int?
  tasks_count    Int?
  status         String         @default("draft")
  // draft | published
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt

  @@map("agency_reports")
}

// ─── Match Queue ──────────────────────────────────────────────────────────────

model MatchQueueEntry {
  id           String   @id @default(cuid())
  agency_id    String   @unique
  agency       Agency   @relation(fields: [agency_id], references: [id])
  tier         String   @default("basic")
  // basic | premium | elite
  score        Float    @default(0)
  status       String   @default("active")
  // active | paused | suspended
  position     Int      @default(0)
  joined_queue DateTime @default(now())
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("match_queue_entries")
}

// ─── Payments (Sandbox / Fake Gateway) ───────────────────────────────────────

model Payment {
  id                  String    @id @default(cuid())
  project_id          String
  project             Project   @relation(fields: [project_id], references: [id])
  user_id             String?
  amount              Float
  payment_method      String    @default("CARTAO_TESTE")
  // CARTAO_TESTE | PIX_FAKE | BOLETO_FAKE | CREDITOS | ALLKOINS
  status              String    @default("PENDENTE")
  // PENDENTE | PAGO | FALHOU | CANCELADO
  gateway             String    @default("FAKE_SANDBOX")
  // FAKE_SANDBOX | STRIPE | PAGARME | ASAAS
  fake_transaction_id String?
  card_last_digits    String?
  card_holder         String?
  notes               String?   @db.LongText
  // Confirmação real de pagamento (status -> PAGO) reaproveita este campo
  // já existente em vez de um novo `confirmed_at` redundante.
  paid_at             DateTime?
  // Idempotência real e persistida (substitui o antigo findFirst+observations
  // em texto livre). Identifica esta TENTATIVA/cobrança específica — ver
  // src/lib/confirm-payment.ts. Formato: fake:{paymentId}:{billingCycleKey}
  // depois de confirmado (ou draft:{projectId}:{cycleKey} enquanto ainda
  // PENDENTE e sem payment_id conhecido pelo chamador).
  idempotency_key     String?   @unique
  // Identifica o ciclo coberto por este pagamento: "avulso" para contratação
  // avulsa, ou "YYYY-MM" para o ciclo mensal efetivamente pago.
  billing_cycle_key   String?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  generated_tasks ProjectTask[] @relation("PaymentGeneratedTasks")
  items           PaymentItem[]

  @@map("payments")
}

// ─── PaymentItem — snapshot congelado dos ProjectProducts cobertos por um
// Payment específico ─────────────────────────────────────────────────────
// Sem isto, Payment não registrava explicitamente QUAIS ProjectProducts
// foram pagos — reprocessamento e auditoria dependiam de reconsultar os
// produtos ATUAIS do projeto, o que quebra assim que um produto é
// adicionado/removido depois do pagamento. Uma vez criado, um PaymentItem
// nunca é alterado (histórico comercial imutável, mesmo padrão dos
// snapshots em ProjectProduct).
model PaymentItem {
  id         String  @id @default(cuid())
  payment_id String
  payment    Payment @relation(fields: [payment_id], references: [id], onDelete: Cascade)

  project_product_id String
  project_product    ProjectProduct @relation(fields: [project_product_id], references: [id])
  product_id         String?
  product            Product?       @relation(fields: [product_id], references: [id], onDelete: SetNull)

  product_name_snapshot String
  unit_price_snapshot   Float
  // Não existe hoje campo de "quantidade contratada" em ProjectProduct —
  // sempre 1 nesta fase (reservado pra quando essa noção existir).
  quantity_snapshot     Int     @default(1)
  total_snapshot        Float
  recurrence_snapshot   String?
  // Ciclo ao qual este item pertence — espelha Payment.billing_cycle_key no
  // momento da criação (fica preservado mesmo se o Payment for editado).
  billing_cycle_key     String?

  created_at DateTime @default(now())

  // Mesmo ProjectProduct não pode aparecer duas vezes no mesmo Payment —
  // como cada Payment já pertence a exatamente um ciclo, isso também cobre
  // "não duas vezes no mesmo Payment E ciclo".
  @@unique([payment_id, project_product_id])
  @@index([payment_id])
  @@index([project_product_id])
  @@map("payment_items")
}

// ─── Expenses (Despesas Operacionais) ────────────────────────────────────────
// Separate from CMV/costs (precificação). These are operating expenses of Allka.

model Expense {
  id                String    @id @default(cuid())
  name              String
  description       String?   @db.LongText
  category          String    @default("Outros")
  // Administrativo | Ferramentas e Sistemas | Marketing | Financeiro |
  // Jurídico/Contábil | Infraestrutura | Pessoas | Operacional | Impostos e Taxas | Outros
  amount            Float
  type              String    @default("fixa")
  // fixa | variável
  recurrence        String    @default("mensal")
  // única | mensal | anual | personalizada
  status            String    @default("prevista")
  // prevista | pendente | paga | atrasada | cancelada
  due_date          DateTime?
  paid_at           DateTime?
  payment_method    String?
  // pix | transferência | cartão | boleto | débito | dinheiro | outro
  department        String?
  // Administrativo | Financeiro | Marketing | Tecnologia | Jurídico | Pessoas | Operacional | Outros
  competence_month  String?
  // Format: "YYYY-MM" — competence month reference
  notes             String?   @db.LongText
  attachment_url    String?   @db.LongText
  // recurrence control
  recurrence_id     String?
  // groups recurring instances — same recurrence_id = same recurring expense series
  is_recurring_base Boolean   @default(false)
  // true = this is the base/template of a recurring series
  created_by        String?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  @@index([status])
  @@index([category])
  @@index([competence_month])
  @@index([recurrence_id])
  @@map("expenses")
}

// ─── Wallets & Ledger ─────────────────────────────────────────────────────────

model Wallet {
  id              String   @id @default(cuid())
  owner_type      String
  // "company" | "agency" | "nomad" | "partner" | "platform"
  owner_id        String
  balance         Float    @default(0)
  blocked_balance Float    @default(0)
  currency        String   @default("BRL")
  status          String   @default("active")
  // "active" | "suspended" | "closed"
  notes           String?  @db.LongText
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  ledger WalletLedger[]

  @@unique([owner_type, owner_id])
  @@index([owner_type])
  @@index([status])
  @@map("wallets")
}

model WalletLedger {
  id              String   @id @default(cuid())
  wallet_id       String
  wallet          Wallet   @relation(fields: [wallet_id], references: [id])
  type            String
  // credit | debit | adjustment | block | unblock | refund | commission | withdrawal | payment | fee | bonus | penalty
  direction       String
  // credit | debit
  amount          Float
  balance_before  Float
  balance_after   Float
  description     String
  category        String?
  status          String   @default("confirmed")
  // pending | confirmed | failed | reversed
  reference_type  String?
  // payment | invoice | withdrawal | commission | expense | project | adjustment
  reference_id    String?
  idempotency_key String?  @unique
  metadata        Json?
  created_by      String?
  notes           String?  @db.LongText
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([wallet_id])
  @@index([type])
  @@index([direction])
  @@index([status])
  @@index([created_at])
  @@index([reference_type, reference_id])
  @@map("wallet_ledger")
}

// ─── Report Configuration & Permissions ──────────────────────────────────────

model ReportConfig {
  id                    String   @id @default(cuid())
  report_key            String   @unique
  // Matches report.id from the frontend catalog: "revenue", "invoices", "cashflow", etc.
  is_active             Boolean  @default(true)
  allowed_account_types String?  @db.LongText
  // JSON: string[] — e.g., ["agencias","empresas","nomades","parceiro","lider"]
  allowed_roles         String?  @db.LongText
  // JSON: string[] — e.g., ["agency_admin","company_admin"]
  allowed_user_ids      String?  @db.LongText
  // JSON: string[] — specific user IDs always allowed
  blocked_user_ids      String?  @db.LongText
  // JSON: string[] — specific user IDs always blocked
  data_scope            String   @default("GLOBAL")
  // GLOBAL | OWN_PROFILE_SCOPE | OWN_COMPANY_SCOPE | OWN_AGENCY_SCOPE | OWN_NOMAD_SCOPE | OWN_PARTNER_SCOPE | OWN_LEADER_SCOPE | CUSTOM_USERS
  can_export            Boolean  @default(true)
  can_change_filters    Boolean  @default(true)
  only_related_data     Boolean  @default(false)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  @@map("report_configs")
}

// ─── Usage Events (platform analytics) ───────────────────────────────────────
// Additive model for page-view and funnel tracking. Writing is opt-in via
// POST /api/reports/usage-event. Reading feeds the Usabilidade indicator.

model UsageEvent {
  id           String   @id @default(cuid())
  user_id      String
  account_type String
  // agencias | empresas | nomades | admin | parceiro
  route        String   @db.VarChar(500)
  // e.g. "/projetos", "/checkout/montagem", "/tarefas"
  event_type   String
  // "page_view" | "login" | "project_start" | "project_abandon"
  // | "checkout_start" | "checkout_complete" | "checkout_abandon"
  session_id   String?
  // client-generated session identifier for funnel grouping
  metadata     String?  @db.LongText
  // JSON: any extra context (product_id, task_id, etc.)
  created_at   DateTime @default(now())

  @@index([user_id])
  @@index([account_type])
  @@index([event_type])
  @@index([created_at])
  @@index([session_id])
  @@map("usage_events")
}

// ─── Squad (plano pós-pago com limite de crédito) ────────────────────────────

model SquadConfig {
  id              String    @id @default(cuid())
  company_id      String    @unique
  company         Company   @relation(fields: [company_id], references: [id])
  credit_limit    Float     @default(10000)
  // Limite máximo que a carteira pode ficar negativa
  monthly_minimum Float     @default(0)
  // Consumo mínimo mensal garantido
  billing_day     Int       @default(10)
  // Dia do mês em que o ciclo fecha (1–28)
  payment_terms   Int       @default(10)
  // Dias após fechamento para vencimento da fatura
  status          String    @default("active")
  // active | paused | cancelled | delinquent
  notes           String?   @db.LongText
  consultant_id   String?
  // Soft ref para User responsável comercial
  started_at      DateTime  @default(now())
  ended_at        DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  cycles SquadCycle[]

  @@map("squad_configs")
}

model SquadCycle {
  id                 String      @id @default(cuid())
  squad_config_id    String
  squad_config       SquadConfig @relation(fields: [squad_config_id], references: [id])
  company_id         String
  started_at         DateTime
  closed_at          DateTime?
  due_at             DateTime?
  status             String      @default("open")
  // open | closed | invoiced | paid | overdue | cancelled
  total_consumed     Float       @default(0)
  // Soma de todos os débitos do ciclo
  minimum_adjustment Float       @default(0)
  // max(0, monthly_minimum - total_consumed)
  total_invoiced     Float       @default(0)
  // max(total_consumed, monthly_minimum)
  invoice_id         String?     @unique
  // FK suave para Invoice quando ciclo é faturado
  notes              String?     @db.LongText
  created_at         DateTime    @default(now())
  updated_at         DateTime    @updatedAt

  @@index([company_id])
  @@index([status])
  @@index([squad_config_id])
  @@map("squad_cycles")
}

// ─── ProjectCredential — Cofre do Projeto ────────────────────────────────────

model ProjectCredential {
  id String @id @default(cuid())

  project_id         String
  project_task_id    String?
  project_product_id String?

  // Identificação
  title         String
  service       String?
  // Ex: "Meta Ads", "Google Analytics", "WordPress Admin"
  url           String?
  username      String?
  password_demo String?
  // DEMO ONLY — never use real passwords here
  notes         String? @db.LongText
  category      String  @default("other")
  // social | ads | analytics | hosting | cms | email | ecommerce | design | other

  // Status operacional
  status String @default("active")
  // active | expiring | expired | rotation_required | shared | revoked | archived

  // Controle demo
  is_demo Boolean @default(true)

  // Alertas de segurança
  requires_rotation Boolean   @default(false)
  rotation_reason   String?
  last_rotated_at   DateTime?
  expires_at        DateTime?

  // Compartilhamento (string IDs — sem FK para evitar deleção acidental)
  shared_until         DateTime?
  shared_with_user_id  String?
  shared_with_nomad_id String?

  // Auditoria
  created_by String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relações
  project         Project         @relation(fields: [project_id], references: [id], onDelete: Cascade)
  project_task    ProjectTask?    @relation(fields: [project_task_id], references: [id], onDelete: SetNull)
  project_product ProjectProduct? @relation(fields: [project_product_id], references: [id], onDelete: SetNull)

  access_logs ProjectCredentialAccessLog[]

  @@unique([project_id, title])
  @@index([project_id])
  @@index([project_task_id])
  @@index([project_product_id])
  @@index([status])
  @@index([category])
  @@index([shared_with_user_id])
  @@index([shared_with_nomad_id])
  @@map("project_credentials")
}

// ─── ProjectCredentialAccessLog — Histórico de acesso ao Cofre ───────────────

model ProjectCredentialAccessLog {
  id String @id @default(cuid())

  credential_id String
  credential    ProjectCredential @relation(fields: [credential_id], references: [id], onDelete: Cascade)

  action         String
  // created | viewed | copied | shared | revoked | rotated | edited | archived | deleted
  actor_type     String?
  // user | nomad | system
  actor_user_id  String?
  actor_nomad_id String?
  details        String? @db.LongText

  created_at DateTime @default(now())

  @@index([credential_id])
  @@index([action])
  @@index([created_at])
  @@index([actor_user_id])
  @@index([actor_nomad_id])
  @@map("project_credential_access_logs")
}
