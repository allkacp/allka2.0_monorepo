generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Auth & Users ────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  username         String?   @unique
  password_hash    String
  name             String
  role             String    @default("company_user")
  // company_user | company_admin | agency_user | agency_admin | nomad | admin | partner
  account_type     String    @default("empresas")
  // empresas | agencias | nomades | admin | parceiro
  is_active        Boolean   @default(true)
  avatar           String?   @db.LongText
  phone            String?
  position         String?
  admin_profile_id String?
  company_id       String?
  company          Company?  @relation(fields: [company_id], references: [id])
  last_login       DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  nomade              Nomade?
  agency              Agency?
  partner             PartnerProfile?
  term_acceptances    TermAcceptance[]
  chat_participations ChatParticipant[]
  sent_messages       ChatMessage[]      @relation("SentMessages")
  course_enrollments  CourseEnrollment[]
  lider_areas         LiderArea[]
  tasks_como_lider    ProjectTask[]      @relation("TaskLiderResponsavel")

  @@map("users")
}

model LiderArea {
  id                    String   @id @default(cuid())
  user_id               String
  user                  User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  area_nome             String
  categorias_permitidas String?  @db.LongText
  produtos_permitidos   String?  @db.LongText
  ativo                 Boolean  @default(true)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  @@map("lider_areas")
}

// ─── Companies (Empresas / Clientes) ─────────────────────────────────────────

model Company {
  id          String   @id @default(cuid())
  name        String
  cnpj        String?  @unique
  email       String?
  phone       String?
  status      String   @default("ativo")
  // ativo | inativo | prospecto | inadimplente
  segment     String?
  address     String?  @db.LongText
  description String?  @db.LongText
  logo        String?  @db.LongText
  website     String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  projects Project[]
  invoices Invoice[]
  users    User[]

  @@map("companies")
}

// ─── Agencies ────────────────────────────────────────────────────────────────

model Agency {
  id             String   @id @default(cuid())
  user_id        String   @unique
  user           User     @relation(fields: [user_id], references: [id])
  name           String
  cnpj           String?  @unique
  email          String?
  phone          String?
  partner_level  String   @default("bronze")
  // bronze | silver | gold | platinum | diamond
  wallet_balance Float    @default(0)
  status         String   @default("ativo")
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  match_queue_entry MatchQueueEntry?

  @@map("agencies")
}

// ─── Nômades ─────────────────────────────────────────────────────────────────

model Nomade {
  id                         String    @id @default(cuid())
  user_id                    String?   @unique
  user                       User?     @relation(fields: [user_id], references: [id])
  name                       String
  email                      String    @unique
  whatsapp                   String?
  avatar                     String?   @db.LongText
  level                      String    @default("bronze")
  // bronze | silver | gold | platinum | diamond | leader
  status                     String    @default("aguardando_aprovacao")
  // ativo | inativo | aguardando_aprovacao | reprovado | pausado
  score                      Int       @default(0)
  tasks_completed_quarter    Int       @default(0)
  tasks_completed_total      Int       @default(0)
  areas_of_interest          String?   @db.LongText
  // JSON: string[]
  registration_date          DateTime  @default(now())
  last_access                DateTime?
  terms_accepted             Boolean   @default(false)
  is_leader                  Boolean   @default(false)
  leader_id                  String?
  min_monthly_goal           Float?
  performance_avg_rating     Float     @default(0)
  performance_on_time        Float     @default(0)
  performance_rejection_rate Float     @default(0)
  created_at                 DateTime  @default(now())
  updated_at                 DateTime  @updatedAt

  qualifications      Qualification[]
  wallet_transactions WalletTransaction[]
  bank_account        BankAccount?
  task_executions     TaskExecution[]
  withdrawal_requests WithdrawalRequest[]
  habilidades         NomadeHabilidade[]

  @@map("nomades")
}

// ─── NomadeHabilidade ────────────────────────────────────────────────────────
// Vínculo estruturado entre nômade e área/categoria/produto para seleção automática.
// Complementa o modelo Qualification (mantido para compatibilidade).

model NomadeHabilidade {
  id        String @id @default(cuid())
  nomade_id String @db.VarChar(30)
  nomade    Nomade @relation(fields: [nomade_id], references: [id], onDelete: Cascade)

  area String @db.VarChar(50)
  // Performance | Design | Conteúdo | Web | Audiovisual

  categoria_produto String? @db.VarChar(100)
  // Categoria do produto, e.g., "Performance e Anúncios Patrocinados"

  produto_id String? @db.VarChar(30)
  // Produto específico (opcional) — link suave, sem FK forçada para evitar cascata

  modelo_tarefa_id String? @db.VarChar(30)
  // CatalogTask específica (opcional) — link suave

  nota_media      Float  @default(0)
  disponibilidade String @default("disponivel")
  // disponivel | indisponivel | pausado

  ativo      Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([nomade_id, area, categoria_produto, produto_id, modelo_tarefa_id])
  @@map("nomade_habilidades")
}

model NomadeLevel {
  id           String   @id @default(cuid())
  slug         String   @unique
  // bronze | silver | gold | platinum | diamond | leader
  name         String
  min_score    Int
  max_score    Int?
  color        String?
  icon         String?
  benefits     String?  @db.LongText
  // JSON: string[]
  requirements String?  @db.LongText
  // JSON: { label: string, value: string }[]
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("nomade_levels")
}

model PartnerLevel {
  id                     String   @id @default(cuid())
  name                   String   @unique
  description            String?  @db.LongText
  icon                   String?
  color                  String?
  gradient               String?
  min_mrr                Int      @default(0)
  max_mrr                Int?
  led_agencies_min       Int      @default(0)
  led_agencies_mrr_min   Int      @default(0)
  premium_project_limit  Int?
  commission_rate        Float    @default(0)
  extra_discount         Float    @default(0)
  receives_leads_premium Boolean  @default(false)
  requires_partner       Boolean  @default(false)
  level_up_bonus_credits Int      @default(0)
  benefits               String?  @db.LongText
  // JSON: string[]
  sort_order             Int      @default(0)
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  @@map("partner_levels")
}

model Qualification {
  id                 String    @id @default(cuid())
  nomade_id          String
  nomade             Nomade    @relation(fields: [nomade_id], references: [id])
  category           String
  task               String
  status             String    @default("teste_pendente")
  // habilitado | pausado | teste_pendente | reprovado
  certification_date DateTime?
  paused_date        DateTime?
  test_required      Boolean   @default(true)
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  @@map("qualifications")
}

model WalletTransaction {
  id            String   @id @default(cuid())
  nomade_id     String
  nomade        Nomade   @relation(fields: [nomade_id], references: [id])
  type          String
  // credit | debit | bonus | penalty | withdrawal
  amount        Float
  description   String   @db.LongText
  date          DateTime @default(now())
  receipt       String?  @db.LongText
  justification String?  @db.LongText

  @@map("wallet_transactions")
}

model BankAccount {
  id           String   @id @default(cuid())
  nomade_id    String   @unique
  nomade       Nomade   @relation(fields: [nomade_id], references: [id])
  bank         String
  agency       String
  account      String
  account_type String   @default("corrente")
  // corrente | poupanca
  cnpj         String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("bank_accounts")
}

// ─── Projects & Tasks ─────────────────────────────────────────────────────────

model Project {
  id                   String    @id @default(cuid())
  title                String
  description          String?   @db.LongText
  client_id            String?
  client               Company?  @relation(fields: [client_id], references: [id])
  status               String    @default("draft")
  // draft | negotiation | awaiting-payment | planning | in-progress | paused | completed | cancelled | paid
  // draft | negotiation | awaiting-payment | planning | in-progress | paused | completed | cancelled
  lifecycle            String    @default("avulso")
  // avulso | mensal
  type                 String?
  // Marketing Digital | Desenvolvimento Web | Design | E-commerce | Desenvolvimento Mobile | Consultoria
  value                Float     @default(0)
  budget               Float     @default(0)
  spent                Float     @default(0)
  progress             Int       @default(0)
  agency               String?
  company_type         String?
  // company | agency | nomad
  consultant           String?
  consultant_email     String?
  team_size            Int       @default(0)
  nomades              String?   @db.LongText
  // JSON: string[]
  bitrix_sync          Boolean   @default(false)
  portfolio_permission Boolean   @default(false)
  overdue              Boolean   @default(false)
  from_lead            Boolean   @default(false)
  billing_day          Int?
  billing_start_date   String?
  start_date           DateTime?
  end_date             DateTime?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  task_executions TaskExecution[]
  invoices        Invoice[]
  products        ProjectProduct[]
  project_tasks   ProjectTask[]
  payments        Payment[]

  @@map("projects")
}

model Specialty {
  id              String   @id @default(cuid())
  name            String
  description     String?  @db.LongText
  hourly_rate     Float    @default(0)
  category        String
  required_skills String?  @db.LongText
  // JSON: string[]
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  task_templates TaskTemplate[]

  @@map("specialties")
}

model TaskTemplate {
  id                   String     @id @default(cuid())
  name                 String
  description          String?    @db.LongText
  specialty_id         String?
  specialty            Specialty? @relation(fields: [specialty_id], references: [id])
  base_price           Float      @default(0)
  complexity           String     @default("basic")
  // basic | intermediate | advanced | premium
  category             String?
  tags                 String?    @db.LongText
  // JSON: string[]
  estimated_hours      Float      @default(1)
  profit_margin        Float      @default(30)
  emergency_multiplier Float      @default(1.5)
  is_active            Boolean    @default(true)
  created_at           DateTime   @default(now())
  updated_at           DateTime   @updatedAt

  executions TaskExecution[]

  @@map("task_templates")
}

model TaskExecution {
  id           String        @id @default(cuid())
  project_id   String?
  project      Project?      @relation(fields: [project_id], references: [id])
  template_id  String?
  template     TaskTemplate? @relation(fields: [template_id], references: [id])
  nomade_id    String?
  nomade       Nomade?       @relation(fields: [nomade_id], references: [id])
  title        String
  description  String?       @db.LongText
  status       String        @default("draft")
  // draft | launched | in_progress | returned | paused | agency_approval | client_approval | approved | rejected | expired
  priority     String        @default("medium")
  // low | medium | high | urgent
  type         String        @default("standard")
  // standard | qualification | learning
  due_date     DateTime?
  delivered_at DateTime?
  approved_at  DateTime?
  rating       Float?
  feedback     String?       @db.LongText
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt

  @@map("task_executions")
}

// ─── Products ─────────────────────────────────────────────────────────────────

model Product {
  id                String   @id @default(cuid())
  name              String
  description       String?  @db.LongText
  short_description String?
  category          String
  tags              String?  @db.LongText
  // JSON: string[]
  base_price        Float    @default(0)
  complexity        String   @default("basic")
  // basic | intermediate | advanced | premium
  visibility        String   @default("{\"company\":true,\"agency\":true,\"partner\":false,\"inHouse\":false}")
  // JSON: ProductVisibility
  image             String?  @db.LongText
  demonstrations    String?  @db.LongText
  // JSON: string[]
  contract_count    Int      @default(0)
  average_rating    Float    @default(0)
  completion_time   String?
  is_active         Boolean  @default(true)
  metadata          String?  @db.LongText
  // JSON: extras do frontend (tasks, recurrence, summaryDescription, pricing calc, etc.)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  variations       ProductVariation[]
  addons           ProductAddon[]
  task_links       ProductCatalogTask[]
  project_products ProjectProduct[]
  project_tasks    ProjectTask[]

  @@map("products")
}

model ProductVariation {
  id                String    @id @default(cuid())
  product_id        String
  product           Product   @relation(fields: [product_id], references: [id], onDelete: Cascade)
  name              String
  // ex: "Até 2 campanhas"
  description       String?   @db.LongText
  // descrição complementar da variação
  price             Float     @default(0)
  // preço absoluto desta variação
  price_modifier    Float     @default(0)
  // modificador relativo sobre o preço base (legado/alternativo)
  deadline_days     Int?
  // prazo de entrega em dias corridos
  scope_description String?   @db.LongText
  // descrição do escopo/quantidade desta variação
  features          String?   @db.LongText
  // JSON: string[] — bullet points do que inclui/muda nesta variação
  sort_order        Int       @default(0)
  is_active         Boolean   @default(true)
  created_at        DateTime  @default(now())
  updated_at        DateTime? @updatedAt
  // nullable: SQLite ALTER TABLE ADD COLUMN não suporta NOT NULL sem DEFAULT literal

  project_products ProjectProduct[]

  @@map("product_variations")
}

model ProductAddon {
  id          String   @id @default(cuid())
  product_id  String
  product     Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  name        String
  description String?  @db.LongText
  price       Float    @default(0)
  category    String?
  created_at  DateTime @default(now())

  @@map("product_addons")
}

// ─── Catalog Tasks (Cadastro de Tarefas) ─────────────────────────────────────

model CatalogTask {
  id          String  @id @default(cuid())
  code        String  @unique
  // ex: "CT-001", gerado automaticamente
  name        String
  category    String
  // ex: "Design e Criação" | "Performance" | "Estratégia"
  subcategory String?
  task_type   String  @default("execution")
  // execution | review | approval | qualification | support
  description String? @db.LongText
  objective   String? @db.LongText

  // Execution config
  default_deadline_days Int?
  default_priority      String  @default("medium")
  // low | medium | high | urgent
  complexity            String  @default("basic")
  // basic | intermediate | advanced | premium
  estimated_hours       Float?
  responsible_type      String?
  // ex: "nomad" | "leader" | "internal"
  requires_access       Boolean @default(false)
  requires_briefing     Boolean @default(false)
  requires_files        Boolean @default(false)

  // Rich content (JSON fields)
  steps              String? @db.LongText
  // JSON: TaskStep[]
  checklist          String? @db.LongText
  // JSON: ChecklistItem[]
  briefing_questions String? @db.LongText
  // JSON: BriefingQuestion[]
  required_files     String? @db.LongText
  // JSON: string[]
  execution_rules    String? @db.LongText
  // JSON: string[]
  conclusion_rules   String? @db.LongText
  internal_guidance  String? @db.LongText

  // Status
  status    String  @default("ativa")
  // ativa | inativa | em_revisao
  is_active Boolean @default(true)
  notes     String? @db.LongText
  // internal observations

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  product_links ProductCatalogTask[]
  project_tasks ProjectTask[]

  @@map("catalog_tasks")
}

// ─── Product ↔ CatalogTask (many-to-many join) ───────────────────────────────

model ProductCatalogTask {
  id              String @id @default(cuid())
  product_id      String
  catalog_task_id String

  product      Product     @relation(fields: [product_id], references: [id], onDelete: Cascade)
  catalog_task CatalogTask @relation(fields: [catalog_task_id], references: [id], onDelete: Cascade)

  // Link-specific overrides
  sort_order   Int     @default(0)
  is_mandatory Boolean @default(true)
  phase        String?
  // ex: "E01", "E02" — etapa do produto onde esta tarefa entra
  notes        String? @db.LongText
  // observação específica deste produto

  created_at DateTime @default(now())

  @@unique([product_id, catalog_task_id])
  @@map("product_catalog_tasks")
}

// ─── ProjectProduct — Product linked to a Project ────────────────────────────

model ProjectProduct {
  id           String            @id @default(cuid())
  project_id   String
  project      Project           @relation(fields: [project_id], references: [id], onDelete: Cascade)
  product_id   String
  product      Product           @relation(fields: [product_id], references: [id])
  variation_id String?
  variation    ProductVariation? @relation(fields: [variation_id], references: [id])

  // Snapshot: preserves commercial history even if product is later edited
  product_name_snapshot     String
  product_code_snapshot     String?
  product_category_snapshot String
  product_price_snapshot    Float   @default(0)
  recurrence_snapshot       String?
  // avulso | mensal

  // Commercial snapshot (filled by the front-end at link time)
  preco_final_cliente_snapshot Float  @default(0)
  comissao_snapshot            Float  @default(0)
  pagador_snapshot             String @default("AGENCIA")
  // AGENCIA | CLIENTE

  // Status
  status            String    @default("PENDENTE")
  // PENDENTE | EM_EXECUCAO | CONCLUIDO | CANCELADO
  start_date        DateTime?
  expected_end_date DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tasks ProjectTask[]

  @@unique([project_id, product_id])
  @@map("project_products")
}

// ─── ProjectTask — Execution task generated from a CatalogTask ───────────────

model ProjectTask {
  id                 String         @id @default(cuid())
  project_id         String
  project            Project        @relation(fields: [project_id], references: [id], onDelete: Cascade)
  project_product_id String
  project_product    ProjectProduct @relation(fields: [project_product_id], references: [id], onDelete: Cascade)
  product_id         String
  product            Product        @relation(fields: [product_id], references: [id])
  catalog_task_id    String?
  catalog_task       CatalogTask?   @relation(fields: [catalog_task_id], references: [id])

  // Snapshots: task model data at the time of creation
  code_snapshot     String?
  name_snapshot     String
  category_snapshot String?

  // Globally unique operational task code — T000001, T000002, …
  task_code String? @unique

  // Task fields
  title                  String
  description            String? @db.LongText
  status                 String  @default("PARA_LANCAMENTO")
  // PARA_LANCAMENTO | EM_LANCAMENTO | AGUARDANDO_INFORMACOES | LIBERADA_PARA_EXECUCAO
  // | EM_EXECUCAO | EM_REVISAO | EM_APROVACAO | CONCLUIDA | CANCELADA | AGUARDANDO_NOMADE
  priority               String  @default("medium")
  // low | medium | high | urgent
  assignee_id            String?
  responsavel_agencia_id String?
  nomade_responsavel_id  String?
  lider_responsavel_id   String?
  // User.id of the leader assigned to qualify this task

  due_date                DateTime?
  start_date              DateTime?
  completed_at            DateTime?
  data_lancamento         DateTime?
  data_liberacao_execucao DateTime?
  data_inicio_execucao    DateTime?
  data_conclusao          DateTime?
  // Prazo de 30 dias para lançar a tarefa — após esta data ela expira automaticamente
  lancamento_expires_at   DateTime?

  sort_order Int     @default(0)
  fase       String?
  // kept for backward compat
  phase      String?

  // JSON snapshots (preserve checklist/steps/briefing from model at time of creation)
  checklist_snapshot String? @db.LongText
  steps_snapshot     String? @db.LongText
  briefing_snapshot  String? @db.LongText
  observations       String? @db.LongText

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  stages             ProjectTaskStage[]
  briefing_answers   TaskBriefingAnswer[]
  attachments        TaskAttachment[]
  assignment_history TaskAssignmentHistory[]
  lider_responsavel  User?                   @relation("TaskLiderResponsavel", fields: [lider_responsavel_id], references: [id])

  @@map("project_tasks")
}

// ─── ProjectTaskStage ─────────────────────────────────────────────────────

model ProjectTaskStage {
  id              String      @id @default(cuid())
  project_task_id String
  project_task    ProjectTask @relation(fields: [project_task_id], references: [id], onDelete: Cascade)

  catalog_step_ref          String?
  // reference code from the source CatalogTask step JSON
  titulo                    String
  descricao                 String? @db.LongText
  ordem                     Int     @default(0)
  status                    String  @default("PENDENTE")
  // PENDENTE | EM_ANDAMENTO | CONCLUIDA | BLOQUEADA
  obrigatoria               Boolean @default(true)
  depende_da_etapa_anterior Boolean @default(true)
  briefing_necessario       Boolean @default(false)
  checklist_snapshot        String? @db.LongText
  // JSON: ChecklistItem[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("project_task_stages")
}

// ─── TaskBriefingAnswer ──────────────────────────────────────────────────

model TaskBriefingAnswer {
  id              String      @id @default(cuid())
  project_task_id String
  project_task    ProjectTask @relation(fields: [project_task_id], references: [id], onDelete: Cascade)

  question_key  String
  // matches the key from briefing_snapshot JSON
  question_text String  @db.LongText
  answer        String? @db.LongText
  files         String? @db.LongText
  // JSON: { name, url, size, mime_type }[]
  links         String? @db.LongText
  // JSON: string[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([project_task_id, question_key])
  @@map("task_briefing_answers")
}

// ─── TaskAttachment ──────────────────────────────────────────────────────────

model TaskAttachment {
  id              String      @id @default(cuid())
  project_task_id String
  project_task    ProjectTask @relation(fields: [project_task_id], references: [id], onDelete: Cascade)

  type         String  @default("file")
  // file | link | reference | delivery
  name         String
  url          String  @db.LongText
  size         Int?
  // bytes
  mime_type    String? @db.LongText
  observations String? @db.LongText
  uploaded_by  String?
  // user id or name

  created_at DateTime @default(now())

  @@map("task_attachments")
}

// ─── TaskAssignmentHistory ────────────────────────────────────────────────────

model TaskAssignmentHistory {
  id              String      @id @default(cuid())
  project_task_id String
  project_task    ProjectTask @relation(fields: [project_task_id], references: [id], onDelete: Cascade)

  nomade_id   String?
  // null when no nomad was found
  criterio    String
  // "nota_media" | "manual"
  nota_nomade Float?
  automatico  Boolean @default(true)
  resultado   String
  // "atribuido" | "sem_nomade_disponivel"
  detalhes    String? @db.LongText
  // JSON: extra info (eligible candidates, rejection reason, etc.)

  created_at DateTime @default(now())

  @@map("task_assignment_history")
}

// ─── SystemAlert ──────────────────────────────────────────────────────────────

model SystemAlert {
  id          String    @id @default(cuid())
  type        String
  // "nomade_nao_encontrado" | "tarefa_atrasada" | etc.
  title       String
  message     String    @db.LongText
  severity    String    @default("warning")
  // "info" | "warning" | "error"
  entity_type String?
  // "project_task" | "project" | etc.
  entity_id   String?
  is_read     Boolean   @default(false)
  read_at     DateTime?
  created_at  DateTime  @default(now())

  @@map("system_alerts")
}

// ─── Financial ────────────────────────────────────────────────────────────────

model Invoice {
  id             String    @id @default(cuid())
  company_id     String?
  company        Company?  @relation(fields: [company_id], references: [id])
  project_id     String?
  project        Project?  @relation(fields: [project_id], references: [id])
  amount         Float
  status         String    @default("pending")
  // pending | paid | overdue | cancelled
  due_date       DateTime?
  paid_at        DateTime?
  description    String?   @db.LongText
  invoice_number String?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  @@map("invoices")
}

model WithdrawalRequest {
  id            String    @id @default(cuid())
  nomade_id     String
  nomade        Nomade    @relation(fields: [nomade_id], references: [id])
  amount        Float
  status        String    @default("aguardando_analise")
  // aguardando_analise | pagamento_agendado | pagamento_efetuado | cancelado | reprovado
  pix_key       String?
  pix_key_type  String?
  // cpf | email | phone | random
  notes         String?   @db.LongText
  reviewed_by   String?
  reviewed_at   DateTime?
  scheduled_for DateTime?
  paid_at       DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  @@map("withdrawal_requests")
}

// ─── Terms ────────────────────────────────────────────────────────────────────

model Term {
  id                   String   @id @default(cuid())
  title                String
  content              String   @db.LongText
  version              String
  acceptance_level     String   @default("usuario")
  // empresa | usuario
  target_account_types String?  @db.LongText
  // JSON: string[]
  is_active            Boolean  @default(true)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  acceptances TermAcceptance[]

  @@map("terms")
}

model TermAcceptance {
  id          String   @id @default(cuid())
  term_id     String
  term        Term     @relation(fields: [term_id], references: [id])
  user_id     String
  user        User     @relation(fields: [user_id], references: [id])
  accepted_at DateTime @default(now())
  ip_address  String?

  @@unique([term_id, user_id])
  @@map("term_acceptances")
}

// ─── Chat ─────────────────────────────────────────────────────────────────────

model Conversation {
  id         String   @id @default(cuid())
  title      String?
  type       String   @default("direct")
  // direct | group | support
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  participants ChatParticipant[]
  messages     ChatMessage[]

  @@map("conversations")
}

model ChatParticipant {
  id              String       @id @default(cuid())
  conversation_id String
  conversation    Conversation @relation(fields: [conversation_id], references: [id])
  user_id         String
  user            User         @relation(fields: [user_id], references: [id])
  role            String       @default("member")
  joined_at       DateTime     @default(now())

  @@unique([conversation_id, user_id])
  @@map("chat_participants")
}

model ChatMessage {
  id              String       @id @default(cuid())
  conversation_id String
  conversation    Conversation @relation(fields: [conversation_id], references: [id])
  sender_id       String
  sender          User         @relation("SentMessages", fields: [sender_id], references: [id])
  content         String       @db.LongText
  is_read         Boolean      @default(false)
  created_at      DateTime     @default(now())

  @@map("chat_messages")
}

// ─── Allkademy ────────────────────────────────────────────────────────────────

model Course {
  id           String   @id @default(cuid())
  title        String
  description  String?  @db.LongText
  category     String
  thumbnail    String?  @db.LongText
  duration     Int?
  is_published Boolean  @default(false)
  is_free      Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  modules     CourseModule[]
  enrollments CourseEnrollment[]

  @@map("courses")
}

model CourseModule {
  id         String   @id @default(cuid())
  course_id  String
  course     Course   @relation(fields: [course_id], references: [id], onDelete: Cascade)
  title      String
  order      Int      @default(0)
  created_at DateTime @default(now())

  lessons Lesson[]

  @@map("course_modules")
}

model Lesson {
  id           String       @id @default(cuid())
  module_id    String
  module       CourseModule @relation(fields: [module_id], references: [id], onDelete: Cascade)
  title        String
  content_type String       @default("video")
  // video | text | quiz
  content_url  String?      @db.LongText
  duration     Int?
  order        Int          @default(0)
  created_at   DateTime     @default(now())

  @@map("lessons")
}

model CourseEnrollment {
  id           String    @id @default(cuid())
  course_id    String
  course       Course    @relation(fields: [course_id], references: [id])
  user_id      String
  user         User      @relation(fields: [user_id], references: [id])
  enrolled_at  DateTime  @default(now())
  progress     Float     @default(0)
  completed_at DateTime?

  @@unique([course_id, user_id])
  @@map("course_enrollments")
}

// ─── Admin ────────────────────────────────────────────────────────────────────

model AdminProfile {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.LongText
  is_master   Boolean  @default(false)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  permissions AdminPermission[]

  @@map("admin_profiles")
}

model AdminPermission {
  id         String       @id @default(cuid())
  profile_id String
  profile    AdminProfile @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  module     String
  action     String
  // view | edit | create | delete | not_applicable
  resource   String?      @db.LongText
  created_at DateTime     @default(now())

  @@unique([profile_id, module, action])
  @@map("admin_permissions")
}

// ─── Partners & Campaigns ─────────────────────────────────────────────────────

model PartnerProfile {
  id                 String   @id @default(cuid())
  user_id            String   @unique
  user               User     @relation(fields: [user_id], references: [id])
  balance            Float    @default(0)
  total_earned       Float    @default(0)
  total_withdrawn    Float    @default(0)
  referral_link      String?
  referral_code      String?  @unique
  status             String   @default("pending")
  // active | suspended | pending
  pix_key            String?
  pix_key_type       String?
  // cpf | email | phone | random
  linked_campaign_id String?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  commissions PartnerCommission[]

  @@map("partner_profiles")
}

model Campaign {
  id               String    @id @default(cuid())
  name             String
  type             String    @default("coupon")
  // coupon | link | referral
  status           String    @default("active")
  // active | paused | ended
  commission_type  String    @default("percentage")
  // percentage | fixed
  commission_value Float     @default(10)
  coupon_code      String?   @unique
  start_date       DateTime?
  end_date         DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  commissions PartnerCommission[]

  @@map("campaigns")
}

model PartnerCommission {
  id           String         @id @default(cuid())
  partner_id   String
  partner      PartnerProfile @relation(fields: [partner_id], references: [id])
  campaign_id  String?
  campaign     Campaign?      @relation(fields: [campaign_id], references: [id])
  amount       Float
  status       String         @default("pending")
  // pending | approved | paid
  company_name String?
  project_name String?
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt

  @@map("partner_commissions")
}

// ─── Match Queue ──────────────────────────────────────────────────────────────

model MatchQueueEntry {
  id           String   @id @default(cuid())
  agency_id    String   @unique
  agency       Agency   @relation(fields: [agency_id], references: [id])
  tier         String   @default("basic")
  // basic | premium | elite
  score        Float    @default(0)
  status       String   @default("active")
  // active | paused | suspended
  position     Int      @default(0)
  joined_queue DateTime @default(now())
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("match_queue_entries")
}

// ─── Payments (Sandbox / Fake Gateway) ───────────────────────────────────────

model Payment {
  id                  String    @id @default(cuid())
  project_id          String
  project             Project   @relation(fields: [project_id], references: [id])
  user_id             String?
  amount              Float
  payment_method      String    @default("CARTAO_TESTE")
  // CARTAO_TESTE | PIX_FAKE | BOLETO_FAKE | CREDITOS | ALLKOINS
  status              String    @default("PENDENTE")
  // PENDENTE | PAGO | FALHOU | CANCELADO
  gateway             String    @default("FAKE_SANDBOX")
  // FAKE_SANDBOX | STRIPE | PAGARME | ASAAS
  fake_transaction_id String?
  card_last_digits    String?
  card_holder         String?
  notes               String?   @db.LongText
  paid_at             DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  @@map("payments")
}
