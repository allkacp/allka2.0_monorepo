DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE"
# Docker Compose local: mysql://allka:allka_dev@mysql:3306/allka
# MySQL local:          mysql://allka:allka_dev@localhost:3306/allka

JWT_SECRET="CHANGE_ME_USE_A_STRONG_SECRET_MIN_32_CHARS"
PORT=3001
NODE_ENV=development

# Senha dos 6 usuários de teste (admin/nomade/agencia/company/partner/lider).
# Se não definida, o seed usa o fallback "123456".
SEED_TEST_USER_PASSWORD="123456"

# Trava de segurança: o seed de usuários de teste é bloqueado em produção.
# Defina "true" apenas para liberar a execução em produção/staging.
ALLOW_TEST_USERS_SEED_IN_PRODUCTION="false"
