{
  "name": "allka-backend",
  "version": "1.0.0",
  "description": "Allka Platform API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:test-users": "tsx seed-test-users.ts",
    "reset:users-password": "node reset-users-password.cjs",
    "db:seed:products": "tsx seed-all-products.ts",
    "db:seed:tasks": "tsx migrate-tasks.ts",
    "db:seed:catalog-tasks": "tsx src/scripts/seed-catalog-tasks.ts",
    "db:seed:agency-projects": "tsx src/scripts/seed-agency-project-fixtures.ts",
    "db:seed:agencia": "tsx prisma/seed-agencia-data.ts",
    "db:seed:empresa": "tsx prisma/seed-empresa-data.ts",
    "db:seed:lider": "tsx prisma/seed-lider-tasks.ts",
    "db:seed:real": "npm run db:seed:agencia && npm run db:seed:empresa && npm run db:seed:lider",
    "db:audit:products": "tsx src/scripts/audit-products.ts",
    "db:repair:product-structure": "tsx src/scripts/repair-product-structure.ts",
    "db:seed:project-tasks": "node seed-in-progress.cjs",
    "db:restore": "tsx restore-data.ts",
    "db:backfill:agency-projects": "tsx src/scripts/backfill-agency-projects.ts",
    "db:studio": "prisma studio",
    "db:reset": "echo '⛔  Proibido em automação. Use: prisma migrate reset --force (manualmente)'",
    "db:healthcheck": "node -e \"require('dotenv').config();const {PrismaClient}=require('@prisma/client');const p=new PrismaClient();Promise.all([p.product.count(),p.project.count(),p.catalogTask.count(),p.projectTask.count()]).then(([pr,pj,ct,pt])=>console.log(JSON.stringify({products:pr,projects:pj,catalogTasks:ct,projectTasks:pt}))).finally(()=>p.$disconnect())\""
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.0.1",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.22.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
