# ─────────────────────────────────────────────────────────────
# Variáveis de Ambiente — Allka 2026 Frontend
# Copie este arquivo para .env.development e ajuste os valores.
# Nunca commitar arquivos .env com valores reais.
# ─────────────────────────────────────────────────────────────

# URL base da API (sem barra final)
VITE_API_URL=http://localhost:3001/api

# Liga/desliga modo mock (sem backend)
VITE_USE_MOCKS=false

# Exibe o seletor de login de teste (apenas dev — nunca true em produção)
VITE_ENABLE_TEST_LOGIN=false
